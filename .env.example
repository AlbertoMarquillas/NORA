# =========================================================
# DJANGO CORE CONFIGURATION
# =========================================================

DJANGO_SECRET_KEY=django-change-this-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1


# =========================================================
# DATABASE
# =========================================================
# Actualmente usas SQLite. Cuando migres a Postgres podrás
# cambiar esta variable.

DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
DATABASE_PATH=persistence/db.sqlite3


# =========================================================
# JWT CONFIGURATION
# =========================================================

JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=1
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True


# =========================================================
# CHANNELS / WEBSOCKETS
# =========================================================

CHANNEL_LAYER_BACKEND=inmemory

# cuando uses redis en producción
REDIS_URL=redis://127.0.0.1:6379/0


# =========================================================
# CORS / FRONTEND
# =========================================================

FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173


# =========================================================
# AUDIO / SPEECH SERVICE
# =========================================================
# rutas para audio generado por el backend

AUDIO_RUNTIME_PATH=runtime/audio


# =========================================================
# LOGGING
# =========================================================

LOG_LEVEL=INFO


# =========================================================
# APPLICATION FLAGS
# =========================================================

ENABLE_SPEECH_SERVICE=True
ENABLE_VISION_SERVICE=True
ENABLE_AUDIO_SERVICE=True